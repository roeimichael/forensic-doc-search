# Copy to `.env` and edit as needed. These OVERRIDE config.yaml at runtime.
# Format: RAG__<SECTION>__<KEY>  (nested via the "__" delimiter). Env wins over YAML.
# This file is the proof that the system is fully config-driven / on-prem.

# ── Embedding ────────────────────────────────────────────────────────────────
RAG__EMBEDDING__MODEL_NAME=BAAI/bge-small-en-v1.5
# Swap to the lighter fallback (remember to also clear the prefixes):
#   RAG__EMBEDDING__MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
#   RAG__EMBEDDING__MAX_SEQ_LENGTH=256
#   RAG__EMBEDDING__QUERY_PREFIX=
#   RAG__EMBEDDING__CHUNK_SIZE / overlap can drop to 200 / 20
RAG__EMBEDDING__DEVICE=cpu

# ── Vector store (Qdrant) ────────────────────────────────────────────────────
RAG__QDRANT__HOST=localhost
RAG__QDRANT__PORT=6333
RAG__QDRANT__COLLECTION=forensic_docs

# ── Hybrid search ────────────────────────────────────────────────────────────
RAG__HYBRID__ENABLED=true

# ── API ──────────────────────────────────────────────────────────────────────
RAG__API__PORT=8000

# ── Paths ────────────────────────────────────────────────────────────────────
RAG__PATHS__SOURCE_DIR=data/generated

# Point at an alternate config file entirely (optional):
# CONFIG_PATH=config.yaml
